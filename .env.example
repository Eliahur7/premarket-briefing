# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# News
NEWS_API_KEY=your_newsapi_key_here

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email delivery (AWS SES)
SES_FROM_EMAIL=briefing@yourdomain.com
SES_TO_EMAIL=you@yourdomain.com

# Slack (optional)
SLACK_WEBHOOK_URL=

# Watchlist — comma separated, no spaces
WATCHLIST=NVDA,AMD,GOOGL,MSFT,PLTR,AVGO,UBER,BAC

# Sector ETFs to track
SECTOR_ETFS=XLK,XLF,XLE,XLV,XLU,XLY,XLI,XLB,XLRE,XLC,XLP

# Schedule (used by EventBridge — cron in UTC)
# 7:30 AM CT = 13:30 UTC (12:30 during CDT)
SCHEDULE_EXPRESSION=cron(30 13 ? * MON-FRI *)

# Dry run mode — print to stdout, skip delivery
DRY_RUN=false
